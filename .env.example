GROQ_API_KEY=
TAVILY_API_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_API_URL=
CREWAI_TRACING_ENABLED=

# Local persistence layer (M0). Default = true (SQLite + JWT + filesystem storage).
# Set USE_LOCAL_DB=false to use real Supabase (requires the URL + service role key above).
USE_LOCAL_DB=false
LOCAL_DB_PATH=data/app.db
BACKEND_BASE_URL=http://127.0.0.1:8091
LOCAL_JWT_SECRET=

# PayPal (M10 — fill when ready)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_API_BASE=https://api-m.sandbox.paypal.com
PAYPAL_WEBHOOK_ID=
NEXT_PUBLIC_PAYPAL_CLIENT_ID=

# Real OAuth (Google + LinkedIn)
# When BOTH client id and secret are set for a provider, the AuthModal's
# "Continue with Google/LinkedIn" buttons redirect the user to the provider's
# real login screen instead of the dev-mode simulator.
#
# Google setup:
#   1. https://console.cloud.google.com/apis/credentials
#   2. Create OAuth client → Application type "Web application"
#   3. Authorized redirect URI: http://127.0.0.1:8091/auth/oauth/google/callback
#   4. Copy Client ID + Client secret here.
# LinkedIn setup:
#   1. https://www.linkedin.com/developers/apps → Create app
#   2. Under "Auth" tab → Authorized redirect URLs:
#      http://127.0.0.1:8091/auth/oauth/linkedin/callback
#   3. Request the "Sign In with LinkedIn using OpenID Connect" product.
#   4. Copy Client ID + Client secret here.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Contact form delivery
# Where /contact/send submissions are emailed. Defaults to endrilika18@yahoo.com if unset.
CONTACT_RECIPIENT=
# To enable real email delivery (Gmail/Yahoo/etc.), fill in the SMTP block below.
# For Gmail, generate an "app password" at https://myaccount.google.com/apppasswords
# For Yahoo, generate one at https://login.yahoo.com/account/security
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
